# =============================================================================
# GOWA-UI Frontend Environment
# =============================================================================
# This file tells the Vite dev server where the gowa backend is.
# The /gowa/* proxy in vite.config.ts forwards requests to this URL.
# =============================================================================

# The gowa backend running on port 3080 (see whatsapp_9.0.0_darwin_arm64/.env)
VITE_DEFAULT_SERVER_URL=http://127.0.0.1:3080
