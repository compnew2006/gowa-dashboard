# ============================================================================
# GOWA-CRM Backend Environment
# Copy to .env and edit before first run.
# ============================================================================

# --- Database (Postgres) ---
# Homebrew Postgres trusts localhost connections for the current OS user.
# `npm run migrate` will create this database if it does not exist.
DATABASE_URL=postgres://noiemany@localhost:5432/gowa_crm

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth secrets ---
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=replace-me-with-a-different-openssl-rand-hex-32
# 32+ char random base64 used to derive the AES-256-GCM key for the device vault
ENCRYPTION_MASTER_KEY=replace-me-with-openssl-rand-base64-32

# --- First-run admin (REQUIRED in production; dev falls back if unset) ---
DEFAULT_ADMIN_EMAIL=admin@gowa-crm.local
DEFAULT_ADMIN_PASSWORD=ChangeMe!2026

# --- gowa upstream (the Go binary this proxy forwards to) ---
GOWA_UPSTREAM_URL=http://127.0.0.1:3080
# Default device credentials stored in the encrypted vault on first run.
# These MUST match APP_BASIC_AUTH in whatsapp_9.0.0_darwin_arm64/.env
GOWA_BASIC_AUTH_USER=admin
GOWA_BASIC_AUTH_PASS=admin123

# --- Webhook ingress (gowa POSTs here if WHATSAPP_WEBHOOK is set) ---
WEBHOOK_SECRET=change-this-to-match-gowa-webhook-secret

# --- CORS (comma-separated origins; * for dev) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Feature flags ---
# When true, incoming webhooks are enriched via Google Gemini intent/sentiment.
# Requires a valid GEMINI_API_KEY and bills against your Google Cloud account.
AI_INTENT_ENABLED=false
GEMINI_API_KEY=

# --- Server ---
PORT=4000
NODE_ENV=development
